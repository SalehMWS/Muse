APP_NAME=novaflow
APP_ENV=development

HTTP_PORT=8080
HTTP_SHUTDOWN_TIMEOUT=15s

LOG_LEVEL=debug

POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_USER=novaflow
POSTGRES_PASSWORD=novaflow
POSTGRES_DB=novaflow
POSTGRES_SSLMODE=disable
POSTGRES_MAX_CONNS=10
POSTGRES_MIN_CONNS=2
POSTGRES_CONN_MAX_LIFETIME=1h

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

MIGRATIONS_DIR=deployments/migrations

JWT_SECRET=change-me-to-a-random-32-plus-character-secret
JWT_ISSUER=novaflow
JWT_AUDIENCE=novaflow-api
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=720h

ARGON2_MEMORY=65536
ARGON2_TIME=3
ARGON2_PARALLELISM=2
ARGON2_SALT_LENGTH=16
ARGON2_KEY_LENGTH=32

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:8090/api/v1/instagram/callback
INSTAGRAM_SCOPES=instagram_business_basic,instagram_business_content_publish
INSTAGRAM_AUTH_BASE_URL=https://www.instagram.com
INSTAGRAM_API_BASE_URL=https://api.instagram.com
INSTAGRAM_GRAPH_BASE_URL=https://graph.instagram.com
INSTAGRAM_TOKEN_ENCRYPTION_KEY=change-me-to-a-random-32-plus-character-secret
INSTAGRAM_STATE_SECRET=change-me-to-a-random-32-plus-character-secret
INSTAGRAM_STATE_TTL=10m
INSTAGRAM_HTTP_TIMEOUT=10s

# AI caption/hashtag engine (OpenAI-compatible chat completions).
# Groq (default): AI_BASE_URL=https://api.groq.com/openai/v1  AI_MODEL=llama-3.1-8b-instant
# OpenRouter:     AI_BASE_URL=https://openrouter.ai/api/v1    AI_MODEL=google/gemini-2.0-flash-001
AI_PROVIDER=groq
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=
AI_MODEL=llama-3.1-8b-instant
AI_MAX_TOKENS=1024
AI_HTTP_TIMEOUT=30s

# Scheduler: how often the in-process runner polls for due schedules.
SCHEDULER_POLL_INTERVAL=10s

# Worker pool: number of concurrent job consumers.
WORKER_CONCURRENCY=4
