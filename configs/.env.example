APP_NAME=novaflow
APP_ENV=development

HTTP_PORT=8080
HTTP_SHUTDOWN_TIMEOUT=15s

LOG_LEVEL=debug

POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_USER=novaflow
POSTGRES_PASSWORD=novaflow
POSTGRES_DB=novaflow
POSTGRES_SSLMODE=disable
POSTGRES_MAX_CONNS=10
POSTGRES_MIN_CONNS=2
POSTGRES_CONN_MAX_LIFETIME=1h

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

MIGRATIONS_DIR=deployments/migrations

JWT_SECRET=change-me-to-a-random-32-plus-character-secret
JWT_ISSUER=novaflow
JWT_AUDIENCE=novaflow-api
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=720h

ARGON2_MEMORY=65536
ARGON2_TIME=3
ARGON2_PARALLELISM=2
ARGON2_SALT_LENGTH=16
ARGON2_KEY_LENGTH=32

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:8090/api/v1/instagram/callback
INSTAGRAM_SCOPES=instagram_business_basic,instagram_business_content_publish
INSTAGRAM_AUTH_BASE_URL=https://www.instagram.com
INSTAGRAM_API_BASE_URL=https://api.instagram.com
INSTAGRAM_GRAPH_BASE_URL=https://graph.instagram.com
INSTAGRAM_TOKEN_ENCRYPTION_KEY=change-me-to-a-random-32-plus-character-secret
INSTAGRAM_STATE_SECRET=change-me-to-a-random-32-plus-character-secret
INSTAGRAM_STATE_TTL=10m
INSTAGRAM_HTTP_TIMEOUT=10s

# AI caption/hashtag engine (OpenAI-compatible chat completions).
# Groq (default): AI_BASE_URL=https://api.groq.com/openai/v1  AI_MODEL=llama-3.1-8b-instant
# OpenRouter:     AI_BASE_URL=https://openrouter.ai/api/v1    AI_MODEL=google/gemini-2.0-flash-001
AI_PROVIDER=groq
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=
AI_MODEL=llama-3.1-8b-instant
AI_MAX_TOKENS=1024
AI_HTTP_TIMEOUT=30s

# Scheduler: how often the in-process runner polls for due schedules.
SCHEDULER_POLL_INTERVAL=10s

# Worker pool: number of concurrent job consumers.
WORKER_CONCURRENCY=4

# Knowledge base / RAG. Embedder: local (deterministic, no key) | openai (uses AI_* + KNOWLEDGE_EMBEDDING_MODEL).
# Vector store: memory (dev) | milvus (KNOWLEDGE_MILVUS_ADDR). EMBEDDING_DIM must match the embedder (local=256, OpenAI text-embedding-3-small=1536).
KNOWLEDGE_EMBEDDER=local
KNOWLEDGE_EMBEDDING_MODEL=text-embedding-3-small
KNOWLEDGE_EMBEDDING_DIM=256
KNOWLEDGE_VECTOR_STORE=memory
KNOWLEDGE_MILVUS_ADDR=localhost:19530
KNOWLEDGE_MILVUS_COLLECTION=novaflow_knowledge
KNOWLEDGE_CHUNK_SIZE=200
KNOWLEDGE_CHUNK_OVERLAP=40
KNOWLEDGE_TOP_K=5

# Observability. APP_VERSION labels every log line and the build_info metric.
# METRICS_ENABLED exposes Prometheus exposition at METRICS_PATH (unauthenticated,
# intended for in-cluster scraping). QUEUE_DEPTH_INTERVAL samples job stream depth.
APP_VERSION=dev
METRICS_ENABLED=true
METRICS_PATH=/metrics
METRICS_QUEUE_DEPTH_INTERVAL=15s

# Grafana admin credentials for the local compose stack (http://localhost:3030).
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# MinIO credentials backing the compose Milvus instance.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# HTTP hardening. BODY_LIMIT caps request bodies in bytes. The timeouts bound
# slow-client attacks; Fiber defaults to no timeout at all. TRUSTED_PROXIES is a
# comma-separated CIDR/IP allowlist — only when it is set does the API trust
# X-Forwarded-For for the client IP (and X-Forwarded-Proto for HSTS). Leave it
# empty unless the API actually runs behind a proxy, or clients can spoof their
# IP and evade rate limits.
HTTP_BODY_LIMIT=4194304
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
HTTP_TRUSTED_PROXIES=

# Rate limiting. Redis-backed sliding window, keyed by client IP. The AUTH tier
# is stricter and applies to /api/v1/auth to blunt credential brute force; the
# general tier applies to all of /api/v1. FAIL_OPEN decides what happens when
# Redis is unreachable: true serves the request, false returns 503.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
RATE_LIMIT_AUTH_REQUESTS=10
RATE_LIMIT_AUTH_WINDOW=1m
RATE_LIMIT_FAIL_OPEN=true

# Security headers and CORS. CORS is disabled while ALLOWED_ORIGINS is empty;
# set an explicit allowlist to enable it. A wildcard origin is rejected outright
# in production and whenever credentials are allowed. HSTS defaults on only in
# production and is emitted only over HTTPS.
SECURITY_CORS_ALLOWED_ORIGINS=
SECURITY_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
SECURITY_CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Correlation-ID,X-Request-ID
SECURITY_CORS_ALLOW_CREDENTIALS=false
SECURITY_CORS_MAX_AGE=12h
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE=8760h
SECURITY_CONTENT_SECURITY_POLICY=default-src 'none'; frame-ancestors 'none'
SECURITY_FRAME_OPTIONS=DENY
SECURITY_REFERRER_POLICY=no-referrer
SECURITY_PERMISSIONS_POLICY=geolocation=(), microphone=(), camera=()
