{
  "uid": "novaflow-api",
  "title": "NovaFlow / API",
  "tags": ["novaflow", "api"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requests / sec",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(novaflow_http_requests_total[5m]))"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error rate (5xx)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(novaflow_http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(novaflow_http_requests_total[5m])), 0.001)"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "p95 latency",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.3 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(novaflow_http_request_duration_seconds_bucket[5m])))"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "In-flight requests",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "novaflow_http_requests_in_flight" }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Throughput by route",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{method}} {{route}}",
          "expr": "sum by (method, route) (rate(novaflow_http_requests_total[5m]))"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latency quantiles",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "p50",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(novaflow_http_request_duration_seconds_bucket[5m])))"
        },
        {
          "refId": "B",
          "legendFormat": "p95",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(novaflow_http_request_duration_seconds_bucket[5m])))"
        },
        {
          "refId": "C",
          "legendFormat": "p99",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(novaflow_http_request_duration_seconds_bucket[5m])))"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Responses by status class",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{status}}",
          "expr": "sum by (status) (rate(novaflow_http_requests_total[5m]))"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Postgres connection pool",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "legendFormat": "acquired", "expr": "novaflow_postgres_connections_acquired" },
        { "refId": "B", "legendFormat": "idle", "expr": "novaflow_postgres_connections_idle" },
        { "refId": "C", "legendFormat": "total", "expr": "novaflow_postgres_connections_total" },
        { "refId": "D", "legendFormat": "max", "expr": "novaflow_postgres_connections_max" }
      ]
    }
  ]
}
